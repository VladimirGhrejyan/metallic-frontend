        "@reduxjs/toolkit": "^2.4.0",
        "@rtk-query/codegen-openapi": "^2.0.0",
        "@tanstack/react-router": "^1.89.0",
        "browser-image-compression": "^2.0.2",
        "heic2any": "^0.0.4",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-dropzone": "^14.3.8",
